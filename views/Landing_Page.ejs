<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>TransitFleets - Event Management</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
    <style>
        * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: Arial, sans-serif;
}

body {
    background-color: #f4f6f9;
    color: #333;
}

/* Navbar */
.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 50px;
    background-color: #0b1c2d;
}

.logo {
    font-size: 24px;
    font-weight: bold;
    color: white;
}

.nav-buttons .btn {
    margin-left: 15px;
}

/* Buttons */
.btn {
    text-decoration: none;
    padding: 10px 18px;
    border-radius: 6px;
    font-size: 14px;
    transition: 0.3s ease;
}

.login-btn {
    background-color: transparent;
    border: 1px solid white;
    color: white;
}

.login-btn:hover {
    background-color: white;
    color: #0b1c2d;
}

.signup-btn {
    background-color: #2a7fff;
    color: white;
}

.signup-btn:hover {
    background-color: #1c60cc;
}

/* Hero Section */
.hero {
    text-align: center;
    padding: 100px 20px;
    background-color: white;
}

.hero h1 {
    font-size: 40px;
    margin-bottom: 20px;
    color: #0b1c2d;
}

.hero p {
    font-size: 18px;
    margin-bottom: 30px;
    color: #555;
}

.hero-buttons .btn {
    margin: 10px;
}

.primary-btn {
    background-color: #2a7fff;
    color: white;
}

.primary-btn:hover {
    background-color: #1c60cc;
}

.secondary-btn {
    background-color: #0b1c2d;
    color: white;
}

.secondary-btn:hover {
    background-color: #000;
}

/* Features */
.features {
    padding: 60px 50px;
    text-align: center;
}

.features h2 {
    margin-bottom: 40px;
    font-size: 28px;
}

.feature-container {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
}

.feature-box {
    background: white;
    padding: 25px;
    width: 300px;
    margin: 15px;
    border-radius: 10px;
    box-shadow: 0px 5px 15px rgba(0,0,0,0.05);
}

.feature-box h3 {
    margin-bottom: 15px;
    color: #0b1c2d;
}

/* Footer */
footer {
    text-align: center;
    padding: 20px;
    background-color: #0b1c2d;
    color: white;
    margin-top: 40px;
}
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar">
        <div class="logo">TransitFleets</div>
        <div class="nav-buttons">
            <!-- <a href="login.html" class="btn login-btn">Login</a> -->
            <a href="/login" class="btn signup-btn">Login</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <h1>Smart Event Management for Fleet Operations</h1>
        <p>
            Manage events, drivers, schedules, and bookings efficiently 
            with TransitFleets Event Management System.
        </p>
        <div class="hero-buttons">
            <!-- <a href="signup.html" class="btn primary-btn">Get Started</a> -->
            <a href="/login" class="btn secondary-btn">Login to Dashboard</a>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features">
        <h2>Why Choose TransitFleets?</h2>
        <div class="feature-container">
            <div class="feature-box">
                <h3>Real-Time Tracking</h3>
                <p>Monitor fleet movement and event coordination live.</p>
            </div>
            <div class="feature-box">
                <h3>Driver Management</h3>
                <p>Assign drivers and manage schedules seamlessly.</p>
            </div>
            <div class="feature-box">
                <h3>Event Scheduling</h3>
                <p>Plan and execute events with structured coordination.</p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <p>© 2026 TransitFleets. All Rights Reserved.</p>
    </footer>

</body>
</html>