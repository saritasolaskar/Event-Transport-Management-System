 


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Driver Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f4f6f9;
        }

        .navbar {
            background-color: #1e293b;
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .navbar h2 {
            margin: 0;
        }

        .logout-btn {
            background-color: #ef4444;
            color: white;
            padding: 8px 15px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .logout-btn:hover {
            background-color: #dc2626;
        }

        .container {
            max-width: 600px;
            margin: 40px auto;
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .container h3 {
            margin-bottom: 20px;
            color: #111827;
        }

        .detail-row {
            margin-bottom: 15px;
            padding: 10px;
            background-color: #f9fafb;
            border-radius: 6px;
        }

        .label {
            font-weight: bold;
            color: #374151;
        }

        .value {
            margin-left: 5px;
            color: #111827;
        }
    </style>
</head>
<body>

    <!-- Top Navbar -->
    <div class="navbar">
        <h2>Welcome to Driver Dashboard</h2>
        <form action="/driver/logout" method="GET">
            <button class="logout-btn">Logout</button>
        </form>
    </div>

    <!-- Driver Details Section -->
    <div class="container">
        <h3>Driver Profile Details</h3>

        <div class="detail-row">
            <span class="label">Username:</span>
            <span class="value"><%= driver.username %></span>
        </div>

        <div class="detail-row">
            <span class="label">Email:</span>
            <span class="value"><%= driver.email %></span>
        </div>

        <div class="detail-row">
            <span class="label">Phone:</span>
            <span class="value"><%=driver_details.phone %></span>
        </div>

        <div class="detail-row">
            <span class="label">License Number:</span>
            <span class="value"><%= driver_details.licenseNumber %></span>
        </div>

        <div class="detail-row">
            <span class="label">Vehicle Type:</span>
            <span class="value"><%= driver_details.vehicleType %></span>
        </div>

        <div class="detail-row">
            <span class="label">Vehicle Number:</span>
            <span class="value"><%= driver_details.vehicleNumber %></span>
        </div>

    </div>

</body>
</html>